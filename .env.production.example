# AIropa Production Environment
# Copy to .env.production and fill in values

# --- Required ---
POSTGRES_PASSWORD=change_me_to_a_strong_password
API_KEY=change_me_to_a_random_api_key

# --- LLM Provider ---
# Options: groq, mistral, openrouter, kilo
LLM_PROVIDER=kilo
GROQ_API_KEY=
MISTRAL_API_KEY=
OPENROUTER_API_KEY=
# Default model for OpenRouter (can be any model on openrouter.ai)
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct
# Kilo AI Gateway (https://kilo.ai/docs/gateway)
KILO_API_KEY=
# Any model from https://api.kilo.ai/api/gateway/models
# KILO_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# --- LLM Feature Flags ---
LLM_CLASSIFICATION_ENABLED=true
LLM_SUMMARY_ENABLED=true
LLM_QUALITY_ENABLED=false
LLM_SHADOW_MODE=false
LLM_BUDGET_MAX_TOKENS=50000

# --- CORS ---
# Add your frontend domain(s), comma-separated
ALLOWED_ORIGINS=https://www.airopa.news,https://airopa.news

# --- Optional Tuning ---
# EU_RELEVANCE_THRESHOLD=3.0
# MAX_ARTICLE_AGE_DAYS=30
# DEBUG=false
